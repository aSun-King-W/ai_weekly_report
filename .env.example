# 环境变量示例文件
# 复制此文件为 .env.local 并填写实际值

# 必需变量
# NextAuth.js配置
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-32-character-secret-here-change-in-production

# GitHub OAuth应用配置
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# DeepSeek AI API配置（兼容OpenAI API格式）
# 注意：变量名保持为ANTHROPIC_API_KEY以保持向后兼容性
ANTHROPIC_API_KEY=sk-your-deepseek-api-key-here

# 可选变量
# 应用基础URL
APP_URL=http://localhost:3000

# 缓存时间配置（秒）
CACHE_TTL_GITHUB=300
CACHE_TTL_AI=3600  # AI API响应缓存时间（DeepSeek API）

# API速率限制配置
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900

# 功能开关
FEATURE_PDF_EXPORT=true
FEATURE_SHARING=true
FEATURE_MULTI_REPO=true